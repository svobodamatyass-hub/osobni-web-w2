---
const { class: className = "", size = "1x1" } = Astro.props;

// Vypočteme CSS grid span třídy na základě vstupu
let spanClass = "";
if (size === "2x2") spanClass = "col-span-1 md:col-span-2 row-span-1 md:row-span-2";
else if (size === "2x1") spanClass = "col-span-1 md:col-span-2 row-span-1";
else if (size === "1x2") spanClass = "col-span-1 row-span-1 md:row-span-2";
else spanClass = "col-span-1 row-span-1";
---

<div class={`group relative overflow-hidden rounded-3xl bg-surface border border-white/5 transition-all duration-500 hover:bg-surface-hover hover:border-white/10 hover:-translate-y-1 ${spanClass} ${className}`}>
  <!-- Glow efekt při hoveru -->
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none rounded-3xl" style="box-shadow: inset 0 0 20px rgba(168, 85, 247, 0.15), 0 0 15px rgba(168, 85, 247, 0.3);"></div>
  
  <div class="relative z-10 w-full h-full p-6 flex flex-col">
    <slot />
  </div>
</div>
