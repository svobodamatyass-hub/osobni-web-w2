---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ═══════════════════════════════════════════ -->
  <!--  HERO SECTION                               -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden px-6">
    
    <!-- Ambient glow blobs -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-purple-600/20 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-indigo-600/20 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center">

      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-white/10 bg-white/5 text-sm text-white/60 mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
        </span>
        Dostupný pro projekty
      </div>

      <!-- Heading -->
      <h1 class="text-6xl md:text-8xl font-extrabold tracking-tight leading-[0.95] mb-6">
        <span class="block text-white/80 text-3xl md:text-4xl font-medium tracking-widest uppercase mb-4 text-sm">Ahoj, já jsem</span>
        <span class="block">Matyáš</span>
        <span class="block text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-violet-400 to-indigo-400">Svoboda</span>
      </h1>

      <!-- Sub -->
      <p class="text-lg md:text-xl text-white/50 max-w-2xl mx-auto leading-relaxed mb-12 font-light">
        Frontend vývojář a UI/UX nadšenec z České republiky. Stavím přesné, 
        <em class="text-white/80 not-italic">dechberoucí</em> digitální zážitky s důrazem na každý detail.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="#about" class="px-7 py-3.5 bg-purple-600 hover:bg-purple-500 rounded-full text-white font-semibold transition-all duration-300 shadow-[0_0_30px_rgba(168,85,247,0.35)] hover:shadow-[0_0_40px_rgba(168,85,247,0.55)] hover:-translate-y-0.5 text-sm">
          Zjistit více o mně ↓
        </a>
        <a href="#contact" class="px-7 py-3.5 rounded-full border border-white/15 text-white/80 hover:text-white hover:border-white/40 font-semibold transition-all duration-300 text-sm">
          Kontaktovat
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/20 text-xs tracking-widest uppercase flex flex-col items-center gap-2">
      <div class="w-px h-12 bg-gradient-to-b from-transparent to-white/20"></div>
      scroll
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  ABOUT SECTION                              -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="about" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">

      <!-- Section label -->
      <p class="text-purple-400 text-sm font-bold uppercase tracking-widest mb-4">01 — O mně</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-16 max-w-2xl">
        Kód + Design =<br/><span class="text-white/40">moje vášeň</span>
      </h2>

      <!-- Bento grid pro about sekci  -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Bio karta – hlavní, velká -->
        <div class="md:col-span-2 bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-500 group">
          <div class="text-4xl mb-5">👋</div>
          <h3 class="text-2xl font-bold mb-4">Jsem Matyáš — kreativní vývojář a detailista.</h3>
          <p class="text-white/50 leading-relaxed mb-4">
            Rád se vrhám do komplexních problémů a měním stovky řádků kódu v čisté a nesmírně plynulé digitální zážitky. 
            Nejraději propojuju strohou, chladnou logiku se špičkovým, funkčním designem.
          </p>
          <p class="text-white/50 leading-relaxed">
            Věřím, že prémiový software by měl nejen fungovat bez sebemenšího zaváhání, ale musí i úchvatně vypadat. 
            Nikdy se nespokojuji s průměrem. 😎
          </p>
        </div>

        <!-- Info karta -->
        <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-500 flex flex-col justify-between">
          <div>
            <h3 class="text-xs uppercase tracking-widest text-white/30 mb-6 font-medium">Základní info</h3>
            <ul class="space-y-4">
              <li class="flex justify-between text-sm border-b border-white/5 pb-3">
                <span class="text-white/40">Lokace</span>
                <strong class="text-white font-medium">🇨🇿 Česká republika</strong>
              </li>
              <li class="flex justify-between text-sm border-b border-white/5 pb-3">
                <span class="text-white/40">Zaměření</span>
                <strong class="text-white font-medium">Frontend & UI/UX</strong>
              </li>
              <li class="flex justify-between text-sm border-b border-white/5 pb-3">
                <span class="text-white/40">Stack</span>
                <strong class="text-white font-medium">JS, Astro, CSS</strong>
              </li>
              <li class="flex justify-between text-sm">
                <span class="text-white/40">Jazyky</span>
                <strong class="text-white font-medium">CZ / EN</strong>
              </li>
            </ul>
          </div>
          <div class="mt-8 text-6xl text-center opacity-10 group-hover:opacity-20 transition-opacity select-none">🇨🇿</div>
        </div>
        
        <!-- Stat: čas od startu projektu -->
        <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-500 flex flex-col justify-center items-center text-center">
          <div class="text-5xl font-extrabold text-purple-400 mb-2" id="years-count">2+</div>
          <p class="text-white/40 text-sm">roky aktivního vývoje</p>
        </div>

        <!-- Motiv / Quote karta -->
        <div class="md:col-span-2 bg-gradient-to-br from-purple-900/20 to-indigo-900/10 border border-purple-500/20 rounded-3xl p-8 hover:-translate-y-1 transition-all duration-500">
          <div class="text-3xl mb-5">💡</div>
          <blockquote class="text-2xl font-medium leading-snug text-white/80 italic mb-4">
            "Design is not just what it looks like. Design is how it works."
          </blockquote>
          <cite class="text-white/30 text-sm not-italic">— Steve Jobs</cite>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  SKILLS / TECH SECTION                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="skills" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      
      <p class="text-purple-400 text-sm font-bold uppercase tracking-widest mb-4">02 — Dovednosti</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-16 max-w-2xl">
        Co mám v arzenálu
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        
        <!-- Frontend -->
        <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-purple-500/15 flex items-center justify-center text-2xl mb-6">🎨</div>
          <h3 class="font-bold text-lg mb-3">Frontend</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Responzivní weby a aplikace, které fungují jak mají a vypadají tak, jak si uživatel zaslouží.</p>
          <div class="flex flex-wrap gap-2">
            {["HTML5", "CSS3", "JavaScript", "React", "Astro", "Tailwind"].map(tech => (
              <span class="px-3 py-1 bg-white/5 rounded-full text-xs border border-white/10 text-white/70">{tech}</span>
            ))}
          </div>
        </div>

        <!-- UI/UX Design -->
        <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-indigo-500/30 hover:-translate-y-1 transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-indigo-500/15 flex items-center justify-center text-2xl mb-6">✏️</div>
          <h3 class="font-bold text-lg mb-3">UI/UX Design</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Věřím v design, který není jen hezký, ale hlavně intuitivní. Každý pixel musí mít smysl.</p>
          <div class="flex flex-wrap gap-2">
            {["Figma", "Design systems", "Glassmorphism", "Dark mode", "Animace"].map(tech => (
              <span class="px-3 py-1 bg-white/5 rounded-full text-xs border border-white/10 text-white/70">{tech}</span>
            ))}
          </div>
        </div>

        <!-- Nástroje -->
        <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-violet-500/30 hover:-translate-y-1 transition-all duration-500">
          <div class="w-12 h-12 rounded-2xl bg-violet-500/15 flex items-center justify-center text-2xl mb-6">⚙️</div>
          <h3 class="font-bold text-lg mb-3">Nástroje</h3>
          <p class="text-white/40 text-sm mb-5 leading-relaxed">Moderní vývojářský workflow s důrazem na efektivitu a správnou organizaci kódu.</p>
          <div class="flex flex-wrap gap-2">
            {["Git", "GitHub", "VS Code", "Node.js", "npm", "Vite"].map(tech => (
              <span class="px-3 py-1 bg-white/5 rounded-full text-xs border border-white/10 text-white/70">{tech}</span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  INTERESTS SECTION                          -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="interests" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      
      <p class="text-purple-400 text-sm font-bold uppercase tracking-widest mb-4">03 — Zájmy</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-16">
        Mimo kód
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
        {[
          { emoji: "🎮", title: "Gaming", desc: "FPS, RPG, sandboxové světy." },
          { emoji: "🎬", title: "Filmy & Série", desc: "Sci-fi, thriller, superhrdinové." },
          { emoji: "⚡", title: "Airsoft", desc: "Taktika a pohyb na hranici." },
          { emoji: "🎵", title: "Hudba", desc: "Playlist šitý na míru k soustředění." },
          { emoji: "📖", title: "Learning", desc: "Youtube, kurzy, nové technologie." },
          { emoji: "🖥️", title: "Tech & Hardware", desc: "Sestavy, periferie, optimalizace." },
          { emoji: "🌐", title: "Web Design", desc: "Inspirace top portfolia světa." },
          { emoji: "☕", title: "Kafe & Kód", desc: "Nejlepší kombo vůbec." },
        ].map(item => (
          <div class="bg-[#0f0f11] border border-white/5 rounded-3xl p-6 hover:border-purple-500/30 hover:-translate-y-1 transition-all duration-500 group cursor-default">
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform duration-300">{item.emoji}</div>
            <h3 class="font-semibold text-base mb-1">{item.title}</h3>
            <p class="text-white/40 text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  CONTACT SECTION                            -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="contact" class="py-32 px-6 relative overflow-hidden">
    
    <!-- Center glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-purple-700/20 blur-[100px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      
      <p class="text-purple-400 text-sm font-bold uppercase tracking-widest mb-4">04 — Kontakt</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
        Stavíme něco<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400">úžasného?</span>
      </h2>
      <p class="text-white/50 text-lg max-w-xl mx-auto mb-14">
        Ozvi se mi. Jsem dostupný pro spolupráci na projektech, freelance práci nebo jen tak na kafe a kód.
      </p>

      <!-- Contact cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        
        <a href="mailto:svobodamatyass@gmail.com" class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-2 transition-all duration-500 group flex flex-col items-center">
          <div class="w-14 h-14 rounded-2xl bg-purple-500/15 flex items-center justify-center text-2xl mb-4 group-hover:bg-purple-500/25 transition-colors">✉️</div>
          <h3 class="font-bold text-base mb-1">E-mail</h3>
          <p class="text-purple-400 text-sm">svobodamatyass@gmail.com</p>
        </a>

        <a href="https://github.com/matyas2240" target="_blank" rel="noopener" class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-2 transition-all duration-500 group flex flex-col items-center">
          <div class="w-14 h-14 rounded-2xl bg-purple-500/15 flex items-center justify-center text-2xl mb-4 group-hover:bg-purple-500/25 transition-colors">🐙</div>
          <h3 class="font-bold text-base mb-1">GitHub</h3>
          <p class="text-purple-400 text-sm">@matyas2240</p>
        </a>

        <a href="https://instagram.com/matyas2240" target="_blank" rel="noopener" class="bg-[#0f0f11] border border-white/5 rounded-3xl p-8 hover:border-purple-500/30 hover:-translate-y-2 transition-all duration-500 group flex flex-col items-center">
          <div class="w-14 h-14 rounded-2xl bg-purple-500/15 flex items-center justify-center text-2xl mb-4 group-hover:bg-purple-500/25 transition-colors">📸</div>
          <h3 class="font-bold text-base mb-1">Instagram</h3>
          <p class="text-purple-400 text-sm">@matyas2240</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  FOOTER                                     -->
  <!-- ═══════════════════════════════════════════ -->
  <footer class="border-t border-white/5 py-10 px-6 text-center text-white/20 text-sm">
    <p>© 2026 Matyáš Svoboda — Designed & built with 💜 & lots of coffee.</p>
  </footer>

</Layout>

<!-- Plynulá navigace (simple sticky nav) -->
<nav id="navbar" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-full border border-white/10 bg-black/60 backdrop-blur-xl flex items-center gap-8 text-sm transition-all duration-300">
  <a href="#hero" class="text-white/50 hover:text-white transition-colors">Úvod</a>
  <a href="#about" class="text-white/50 hover:text-white transition-colors">O mně</a>
  <a href="#skills" class="text-white/50 hover:text-white transition-colors">Dovednosti</a>
  <a href="#interests" class="text-white/50 hover:text-white transition-colors">Zájmy</a>
  <a href="#contact" class="px-4 py-1.5 bg-purple-600 hover:bg-purple-500 text-white rounded-full transition-colors">Kontakt</a>
</nav>

<style>
  html { scroll-behavior: smooth; }
  
  /* Intersection observer animace pro sekce */
  section {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  section.visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* Hero je hned vidět */
  #hero {
    opacity: 1;
    transform: none;
  }
</style>

<script>
  // Scroll animace sekcí
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add('visible')),
    { threshold: 0.1 }
  );
  document.querySelectorAll('section:not(#hero)').forEach(s => observer.observe(s));
</script>
