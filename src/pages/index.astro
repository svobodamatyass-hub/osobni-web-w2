---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ═══════════════════════════════════════════ -->
  <!--  HERO                                       -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden px-6">
    
    <!-- Animated mesh gradient blobs -->
    <div class="absolute top-[10%] -left-40 w-[500px] h-[500px] bg-purple-600/15 rounded-full blur-[150px] pointer-events-none" style="animation: meshMove 20s ease-in-out infinite;"></div>
    <div class="absolute bottom-[10%] -right-40 w-[400px] h-[400px] bg-indigo-600/15 rounded-full blur-[150px] pointer-events-none" style="animation: meshMove 15s ease-in-out 5s infinite;"></div>
    <div class="absolute top-[60%] left-[30%] w-[300px] h-[300px] bg-violet-700/10 rounded-full blur-[120px] pointer-events-none" style="animation: meshMove 25s ease-in-out 10s infinite;"></div>

    <div class="relative z-10 max-w-5xl mx-auto text-center">

      <!-- Status badge -->
      <div class="hero-element inline-flex items-center gap-2.5 px-5 py-2 rounded-full border border-white/8 bg-white/[0.03] text-sm text-white/80 mb-10 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)]"></span>
        </span>
        Otevřený novým výzvám
      </div>

      <!-- Heading -->
      <h1 class="hero-element text-[clamp(3rem,8vw,7rem)] font-black tracking-[-0.04em] leading-[0.9] mb-8">
        <span class="block text-white/80 text-base md:text-lg font-medium tracking-[0.3em] uppercase mb-6" style="font-family: 'Space Grotesk', sans-serif;">Ahoj, já jsem</span>
        <span class="block text-white">Matyáš</span>
        <span class="block text-gradient">Svoboda.</span>
      </h1>

      <!-- Sub -->
      <p class="hero-element text-lg md:text-xl text-white/80 max-w-xl mx-auto leading-relaxed mb-14 font-light">
        Vytvářím digitální zážitky, u kterých se chceš zastavit.<br class="hidden md:block"/>
        Precizní kód. Minimalistický design. Maximální dojem.
      </p>

      <!-- CTA -->
      <div class="hero-element flex flex-wrap items-center justify-center gap-5">
        <a href="#about" class="group px-8 py-4 bg-purple-600 hover:bg-purple-500 rounded-full text-white font-semibold transition-all duration-500 shadow-[0_0_40px_rgba(168,85,247,0.3)] hover:shadow-[0_0_60px_rgba(168,85,247,0.5)] hover:-translate-y-1 text-sm tracking-wide">
          Poznej mě blíž 
          <span class="inline-block group-hover:translate-y-0.5 transition-transform">↓</span>
        </a>
        <a href="#contact" class="px-8 py-4 rounded-full border border-white/10 text-white/60 hover:text-white hover:border-white/30 hover:bg-white/[0.03] font-semibold transition-all duration-500 text-sm tracking-wide">
          Napsat mi
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
      <div class="w-5 h-8 rounded-full border border-white/15 flex justify-center pt-1.5">
        <div class="w-1 h-2 bg-white/30 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  O MNĚ                                     -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="about" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">

      <p class="text-purple-400/80 text-xs font-semibold uppercase tracking-[0.25em] mb-5" style="font-family: 'Space Grotesk', sans-serif;">01 — O mně</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-20 max-w-2xl leading-[1.1]">
        Posedlý detaily.<br/><span class="text-white/60">Poháněný zvědavostí.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <!-- Bio -->
        <div class="md:col-span-2 bento-card card-reveal">
          <h3 class="text-xl font-bold mb-5 leading-snug">
            Jsem Matyáš — designuju a programuju weby,<br/>které lidi chtějí používat znovu.
          </h3>
          <p class="text-white/80 leading-relaxed mb-4 text-[15px]">
            Nejsem typ, co udělá „aby to fungovalo" a jde dál. Rád si s věcmi hraju, dokud nefungují krásně — od struktury kódu přes animace až po ten poslední stín pod tlačítkem.
          </p>
          <p class="text-white/80 leading-relaxed text-[15px]">
            Věřím, že kvalitní web poznáš podle toho, čeho si na první pohled nevšimneš. Moje práce je v detailech: plynulé přechody, dokonalé zarovnání, promyšlená hierarchie.
          </p>
        </div>

        <!-- Info -->
        <div class="bento-card card-reveal flex flex-col justify-between">
          <div>
            <h3 class="text-[11px] uppercase tracking-[0.2em] text-white/80 mb-6 font-medium" style="font-family: 'Space Grotesk', sans-serif;">Základní info</h3>
            <ul class="space-y-4">
              <li class="flex justify-between text-sm border-b border-white/[0.04] pb-3">
                <span class="text-white/60">Lokace</span>
                <strong class="text-white/80 font-medium">Česko 🇨🇿</strong>
              </li>
              <li class="flex justify-between text-sm border-b border-white/[0.04] pb-3">
                <span class="text-white/60">Zaměření</span>
                <strong class="text-white/80 font-medium">Frontend & UI</strong>
              </li>
              <li class="flex justify-between text-sm border-b border-white/[0.04] pb-3">
                <span class="text-white/60">Stack</span>
                <strong class="text-white/80 font-medium">JS · Astro · CSS</strong>
              </li>
              <li class="flex justify-between text-sm">
                <span class="text-white/60">Jazyky</span>
                <strong class="text-white/80 font-medium">CZ / EN</strong>
              </li>
            </ul>
          </div>
        </div>
        
        <!-- Stat -->
        <div class="bento-card card-reveal flex flex-col justify-center items-center text-center py-12">
          <div class="text-6xl font-black text-gradient mb-2">1</div>
          <p class="text-white/60 text-sm font-medium">měsíc aktivního vývoje</p>
          <div class="w-12 h-px bg-gradient-to-r from-transparent via-purple-500/30 to-transparent mt-5 mb-4"></div>
          <p class="text-white/80 text-xs">a tohle je teprve rozjezd.</p>
        </div>

        <!-- Quote -->
        <div class="md:col-span-2 bento-card card-reveal relative" style="background: linear-gradient(135deg, rgba(88,28,135,0.12), rgba(49,46,129,0.06));">
          <div class="absolute top-6 left-8 text-6xl text-purple-500/10 font-serif leading-none select-none">"</div>
          <blockquote class="text-xl md:text-2xl font-medium leading-relaxed text-white/70 mt-8 mb-5 relative z-10">
            „The details are not the details. They make the design."
          </blockquote>
          <cite class="text-white/80 text-sm not-italic font-medium tracking-wide">— Charles Eames</cite>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  DOVEDNOSTI                                 -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="skills" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      
      <p class="text-purple-400/80 text-xs font-semibold uppercase tracking-[0.25em] mb-5" style="font-family: 'Space Grotesk', sans-serif;">02 — Dovednosti</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-20 max-w-2xl leading-[1.1]">
        Nástroje,<br/><span class="text-white/60">které ovládám.</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        
        <!-- Frontend -->
        <div class="bento-card card-reveal">
          <div class="w-11 h-11 rounded-xl bg-purple-500/10 flex items-center justify-center text-xl mb-6 border border-purple-500/10">🎨</div>
          <h3 class="font-bold text-lg mb-3">Frontend</h3>
          <p class="text-white/70 text-sm mb-6 leading-relaxed">Čisté rozhraní, které reaguje na každém zařízení — od návrhu rovnou do kódu.</p>
          <div class="flex flex-wrap gap-2">
            {["HTML5", "CSS3", "JavaScript", "React", "Astro", "Tailwind"].map(tech => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        </div>

        <!-- UI/UX -->
        <div class="bento-card card-reveal">
          <div class="w-11 h-11 rounded-xl bg-indigo-500/10 flex items-center justify-center text-xl mb-6 border border-indigo-500/10">✏️</div>
          <h3 class="font-bold text-lg mb-3">UI/UX Design</h3>
          <p class="text-white/70 text-sm mb-6 leading-relaxed">Designuju rozhraní, kde každý klik dává smysl. Intuice před komplexitou.</p>
          <div class="flex flex-wrap gap-2">
            {["Figma", "Design Systems", "Prototyping", "Dark Mode", "Motion"].map(tech => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        </div>

        <!-- Nástroje -->
        <div class="bento-card card-reveal">
          <div class="w-11 h-11 rounded-xl bg-violet-500/10 flex items-center justify-center text-xl mb-6 border border-violet-500/10">⚙️</div>
          <h3 class="font-bold text-lg mb-3">Tooling</h3>
          <p class="text-white/70 text-sm mb-6 leading-relaxed">Moderní workflow na automatizaci. Správné nástroje = rychlejší výsledek.</p>
          <div class="flex flex-wrap gap-2">
            {["Git", "GitHub", "VS Code", "Node.js", "npm", "Vite"].map(tech => (
              <span class="tech-tag">{tech}</span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  ZÁJMY                                      -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="interests" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      
      <p class="text-purple-400/80 text-xs font-semibold uppercase tracking-[0.25em] mb-5" style="font-family: 'Space Grotesk', sans-serif;">03 — Mimo kód</p>
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-20 leading-[1.1]">
        Co mě nabíjí.
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { emoji: "🎮", title: "Gaming", desc: "Otevřené světy, taktické přestřelky a pozdní večery." },
          { emoji: "🎬", title: "Filmy", desc: "Sci-fi, thriller, Marvel." },
          { emoji: "⚡", title: "Airsoft", desc: "Terén, strategie a pořádná dávka adrenalinu." },
          { emoji: "🎵", title: "Hudba", desc: "Lo-fi beats, co mě drží v zóně." },
          { emoji: "📖", title: "Učení", desc: "YouTube, kurzy, nové technologie." },
          { emoji: "🖥️", title: "Hardware", desc: "Sestavy, upgrady a honba za FPS." },
          { emoji: "🌐", title: "Web Design", desc: "Inspirace z nejlepších portfolií." },
          { emoji: "☕", title: "Kafe + Kód", desc: "Svatá kombinace." },
        ].map(item => (
          <div class="bento-card card-reveal !p-5 group cursor-default">
            <div class="text-2xl mb-3 group-hover:scale-125 group-hover:-rotate-6 transition-transform duration-500 inline-block">{item.emoji}</div>
            <h3 class="font-semibold text-sm mb-1 text-white/80">{item.title}</h3>
            <p class="text-white/60 text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- ═══════════════════════════════════════════ -->
  <!--  KONTAKT                                    -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="contact" class="py-32 px-6 relative overflow-hidden">
    
    <!-- Ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[250px] bg-purple-700/15 blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      
      <p class="text-purple-400/80 text-xs font-semibold uppercase tracking-[0.25em] mb-5" style="font-family: 'Space Grotesk', sans-serif;">04 — Kontakt</p>
      <h2 class="text-4xl md:text-6xl font-bold tracking-tight mb-6 leading-[1.05]">
        Pojďme postavit<br/>
        <span class="text-gradient">něco výjimečného.</span>
      </h2>
      <p class="text-white/70 text-lg max-w-lg mx-auto mb-16 leading-relaxed">
        Mám prostor pro nový projekt. Napiš mi, zavoláme si, nebo to probereme u kafe — nejlepší nápady stejně vznikají offline.
      </p>

      <!-- Contact cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        
        <a href="mailto:svobodamatyass@gmail.com" class="no-cursor-scale bento-card card-reveal !text-center flex flex-col items-center">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-xl mb-5 border border-purple-500/10">✉️</div>
          <h3 class="font-bold text-sm mb-1.5">E-mail</h3>
          <p class="text-purple-400/70 text-xs">svobodamatyass@gmail.com</p>
        </a>

        <div class="no-cursor-scale bento-card card-reveal !text-center flex flex-col items-center">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-xl mb-5 border border-purple-500/10">🐙</div>
          <h3 class="font-bold text-sm mb-1.5 mt-2">GitHub</h3>
        </div>

        <a href="https://instagram.com/matyas2240" target="_blank" rel="noopener" class="no-cursor-scale bento-card card-reveal !text-center flex flex-col items-center">
          <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-xl mb-5 border border-purple-500/10">📸</div>
          <h3 class="font-bold text-sm mb-1.5">Instagram</h3>
          <p class="text-purple-400/70 text-xs">@matyas2240</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!--  FOOTER                                     -->
  <!-- ═══════════════════════════════════════════ -->
  <footer class="border-t border-white/[0.04] py-10 px-6 text-center text-white/80 text-xs tracking-wide">
    <p>© 2026 Matyáš Svoboda — postaveno s 💜, čistým kódem a víc kafem, než je zdravý.</p>
  </footer>

</Layout>

<!-- Floating nav -->
<nav id="navbar" class="fixed top-5 left-1/2 -translate-x-1/2 z-50 px-1.5 py-1.5 rounded-full border border-white/[0.06] bg-black/50 backdrop-blur-2xl flex items-center gap-1 text-[13px] transition-all duration-300">
  <a href="#hero" class="px-4 py-2 text-white/80 hover:text-white rounded-full hover:bg-white/[0.05] transition-all duration-300">Úvod</a>
  <a href="#about" class="px-4 py-2 text-white/80 hover:text-white rounded-full hover:bg-white/[0.05] transition-all duration-300">O mně</a>
  <a href="#skills" class="px-4 py-2 text-white/80 hover:text-white rounded-full hover:bg-white/[0.05] transition-all duration-300">Dovednosti</a>
  <a href="#interests" class="px-4 py-2 text-white/80 hover:text-white rounded-full hover:bg-white/[0.05] transition-all duration-300">Zájmy</a>
  <a href="#contact" class="px-5 py-2 bg-purple-600/90 hover:bg-purple-500 text-white rounded-full transition-all duration-300 font-medium shadow-[0_0_20px_rgba(168,85,247,0.2)]">Kontakt</a>
</nav>

<style>
  html { scroll-behavior: smooth; }
  
  /* Hero staggered animation */
  .hero-element {
    opacity: 0;
    transform: translateY(30px);
    animation: heroReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-element:nth-child(1) { animation-delay: 0.1s; }
  .hero-element:nth-child(2) { animation-delay: 0.25s; }
  .hero-element:nth-child(3) { animation-delay: 0.4s; }
  .hero-element:nth-child(4) { animation-delay: 0.55s; }
  
  @keyframes heroReveal {
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* Sections fade in */
  section:not(#hero) {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1), transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
  }
  section.visible {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }
  #hero { opacity: 1; transform: none; }
  
  /* Nav */
  nav { animation: navSlide 0.6s 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
  @keyframes navSlide {
    from { opacity: 0; transform: translateY(-20px) translateX(-50%); }
    to { opacity: 1; transform: translateY(0) translateX(-50%); }
  }
</style>

<script>
  // Section reveal
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        // Stagger individual cards inside section
        const cards = e.target.querySelectorAll('.card-reveal');
        cards.forEach((card, i) => {
          setTimeout(() => card.classList.add('visible'), i * 120);
        });
      }
    }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('section:not(#hero)').forEach(s => observer.observe(s));
  
  // Active nav highlighting
  const sections = document.querySelectorAll('section');
  const navLinks = document.querySelectorAll('nav a');
  
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.remove('text-white', 'bg-white/[0.05]');
          link.classList.add('text-white/80');
          if (link.getAttribute('href') === '#' + entry.target.id && !link.classList.contains('bg-purple-600/90')) {
            link.classList.add('text-white', 'bg-white/[0.05]');
            link.classList.remove('text-white/80');
          }
        });
      }
    });
  }, { threshold: 0.3 });
  
  sections.forEach(s => navObserver.observe(s));
</script>
